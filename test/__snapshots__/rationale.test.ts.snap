// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`rationale templating — keep path per category (done-conditions for 5.2) > cache: Redis-native-structures gate 1`] = `"Keep redis:leaderboard — ZADD/ZRANGE (leaderboards); PUBLISH/SUBSCRIBE; XADD (streams); EVAL (Lua); INCR-heavy rate limiting trips Redis-native structures with no clean Postgres equivalent at the same latency: sorted sets (leaderboards), pub/sub, streams, Lua scripting, INCR-heavy rate limiting. Postgres alternative UNLOGGED table + pg_cron TTL sweep would still pay this cost: each detected structure has no single-query Postgres equivalent at Redis's latency; the verdict names the specific structure it found. Evidence: src/scores.ts:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > cache: fan-out-calls-per-request bands keep (A9) 1`] = `"Keep redis:feed — fan-out-calls-per-request observed 12 calls/request exceeds value >= 10 calls/request. Postgres alternative UNLOGGED table + pg_cron TTL sweep would still pay this cost: high per-request cache fan-out multiplies the 0.7ms-vs-0.1ms Postgres/Redis gap across every reachable call, which a single cache read would hide inside a typical 50-200ms request. Evidence: src/feed.ts:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > document: change-streams gate (.watch( in harvested evidence) 1`] = `"Keep mongodb:orders — change streams in use; sharding config present trips Change streams or sharding actively used is a qualitative keep gate. Postgres alternative JSONB column + GIN index would still pay this cost: change-stream consumers and shard-aware routing have no Postgres equivalent that preserves the same operational model. Evidence: app/orders.py:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > document: field-level-update gate ($inc on a multi-KB doc) 1`] = `"Keep mongodb:profiles — $inc counters on documents estimated over ~2KB; $push array updates on documents estimated over ~2KB trips Frequent field-level mutators ($inc counters, $push arrays) on multi-KB documents trip the TOAST rewrite cost on every update. Postgres alternative JSONB column + GIN index would still pay this cost: each $inc rewrites the full TOASTed document plus indexes. Evidence: app/documents.py:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > geospatial: renders the keep template from real threshold data (gate not yet wired) 1`] = `"Keep mapserver:tiles — tile-rendering pipeline or similar non-DB GIS server feature detected trips Keep is reserved for niche server-product features that aren't database features at all (e.g. tile-rendering pipelines). Postgres alternative PostGIS would still pay this cost: tile rendering and similar server-product features sit outside what any SQL geospatial extension does, PostGIS included. Evidence: src/tiles.ts:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > graph: variable-length-or-gds gate 1`] = `"Keep neo4j:social — variable-length traversal, e.g. [:X*1..]; graph-algorithm library usage (PageRank, community detection, ...) trips Variable-length deep traversal as the core access pattern, or GDS-style algorithms, is a keep gate. Postgres alternative Recursive CTEs (plain SQL) would still pay this cost: variable-length traversal and GDS-style algorithms have no constant-shape SQL translation; recursive CTEs need a depth cap that this access pattern doesn't have. Evidence: src/graph.ts:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > olap: scanned-data-size-gb bands keep 1`] = `"Keep clickhouse:warehouse — scanned-data-size-gb observed 5,000 GB exceeds value < 500 GB | 500 <= value < 3,072 GB | value >= 3,072 GB (independent: https://dataskew.io/blog/metabase-duckdb-local-analytics/). Postgres alternative pg_analytics (columnar/vectorized execution over Parquet) would still pay this cost: high concurrent BI usage or cross-org data sharing push toward a warehouse regardless of scanned size — see olap.bi-concurrency-cross-org-gate. Evidence: dbt/models/fact_events.sql:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > queue: est-peak-msgs-sec bands keep 1`] = `"Keep kafka:events — est-peak-msgs-sec observed 15,000-20,000 msgs/sec exceeds value < 1,000 msgs/sec | 1,000 <= value < 10,000 msgs/sec | value >= 10,000 msgs/sec (independent: https://medium.com/@the_atomic_architect/postgresql-replaced-my-message-queue-and-taught-me-skip-locked-along-the-way-87d59e5b9525). Postgres alternative pgmq extension would still pay this cost: consumer transactions at this rate cause MVCC bloat and WAL pile-up; Kafka's batching/sequential I/O is built for the range above ~10k msgs/sec. Evidence: docker-compose.yml:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > search: log-analytics gate 1`] = `"Keep elasticsearch:logs — daily-index naming pattern; Logstash/Beats present in compose; aggregations/faceting as the primary workload trips Log-analytics usage shape — daily indices, Logstash/Beats in compose, heavy aggregations as the primary workload — is a qualitative keep gate independent of corpus size. Postgres alternative tsvector + pg_trgm would still pay this cost: log-analytics access patterns (daily indices, heavy aggregation) are what dedicated search/log engines are built for; tsvector/pg_trgm targets keyword search with basic ranking, not this shape. Evidence: src/logs.ts:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > timeseries: ingest-rows-per-sec bands keep 1`] = `"Keep influxdb:metrics — ingest-rows-per-sec observed 750,000 rows/sec exceeds value < 500,000 rows/sec | value >= 500,000 rows/sec (vendor: https://medium.com/timescale/timescaledb-vs-influxdb-purpose-built-differently-for-time-series-data-36489299877). Postgres alternative TimescaleDB extension (hypertables) would still pay this cost: sustained single-node ingest above ~500k rows/sec, or existing InfluxDB-3.0-specific features/Grafana-Flux dashboards, push the migration-cost balance toward keeping InfluxDB — see timeseries.incumbent-dependency-gate. Evidence: config/ingest.yml:1."`;

exports[`rationale templating — keep path per category (done-conditions for 5.2) > vector: count-vectors bands keep 1`] = `"Keep pinecone:embeddings — count-vectors observed 150,000,000-200,000,000 vectors exceeds value < 5,000,000 vectors | 5,000,000 <= value < 50,000,000 vectors | value >= 100,000,000 vectors (vendor: https://supabase.com/blog/pgvector-vs-pinecone). Postgres alternative pgvector (HNSW index) would still pay this cost: multi-tenant serverless isolation needs — see vector.multitenant-serverless-gate — matter more than raw count once a deployment is past dedicated-engine scale. Evidence: src/vectors.ts:1."`;
